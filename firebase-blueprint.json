{
  "entities": {
    "Product": {
      "title": "Prodotto",
      "description": "Un prodotto nel catalogo aziendale",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Titolo del prodotto" },
        "description": { "type": "string", "description": "Descrizione dettagliata" },
        "internalCode": { "type": "string", "description": "Codice interno aziendale" },
        "imageUrl": { "type": "string", "description": "URL dell'immagine del prodotto" },
        "price": { "type": "number", "description": "Prezzo del prodotto" },
        "category": { "type": "string", "description": "Categoria del prodotto" },
        "brand": { "type": "string", "description": "Marchio del prodotto" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" }
      },
      "required": ["title", "description", "internalCode", "price"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collezione dei prodotti del catalogo"
    }
  }
}
