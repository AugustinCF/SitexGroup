rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'description', 'internalCode', 'price', 'imageUrl', 'category', 'brand', 'createdAt', 'updatedAt', 'creatorId']) &&
             data.keys().size() == 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.internalCode is string && data.internalCode.size() <= 50 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.brand is string &&
             data.imageUrl is string &&
             data.creatorId == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && isValidProduct(request.resource.data) && request.resource.data.updatedAt == request.time && request.resource.data.creatorId == resource.data.creatorId;
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }
  }
}
